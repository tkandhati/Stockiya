ANTHROPIC_API_KEY=
MODEL=claude-haiku-4-5

# 1 = bundled fixtures (UI dev only — DO NOT TRADE ON THESE PRICES)
# 0 = live Yahoo Finance data (recommended)
DEMO_MODE=0

# yahoo (default) | bhavcopy (TODO)
DATA_SOURCE=yahoo

# 1 = sure-shot only — often 0 picks/day; high conviction when something fires
# 0 = relaxed — more picks per day; original behavior
STRICT_MODE=1
