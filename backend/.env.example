# ------------------------------------------------------------
# Stockiya backend environment
#
# setup.bat (and start.bat if backend/.env is missing) copies this file
# to backend/.env on first run. Edit backend/.env (NOT this file) once
# you already have one; git pulls will not touch backend/.env.
# ------------------------------------------------------------

# ---- DATA SOURCE ----
# Default: live Yahoo Finance. Every pipeline run fetches fresh EOD bars
# per ticker; there is no local cache (yet). Requires outbound internet.
#
# On a firewalled corporate network where Yahoo is blocked, flip to
# `DEMO_MODE=1` below (synthetic data — UI verification only, NOT tradable).
# For fully offline real prices, populate a bhavcopy cache and set
# `DATA_SOURCE=bhavcopy` + `STOCKYA_OHLCV_DIR=<abs path>`.

DATA_SOURCE=yahoo

# ---- DEMO MODE ----
# 0 = real data via DATA_SOURCE above
# 1 = synthetic in-memory OHLCV. Overrides DATA_SOURCE. UI/dev only.
#     DO NOT trade on demo prices.
DEMO_MODE=0

# ---- UNIVERSE ----
# nifty50 (fast) / nifty100 / nifty200 / nifty500 (~456 tickers, curated)
# custom = read tickers from config/universe_custom.txt (one per line).
STOCKYA_UNIVERSE=nifty100

# ---- OHLCV CACHE (only used when DATA_SOURCE=bhavcopy) ----
# Absolute path to a directory containing <SYMBOL>.NS.csv files
# (columns: Date, Open, High, Low, Close, Volume). Populate this yourself;
# Stockya only reads from it, never writes.
# STOCKYA_OHLCV_DIR=

# ---- POSITION SIZER ----
# Account size in INR for [PS] Position Sizer share-count math.
# STOCKYA_ACCOUNT_VALUE=100000

# ---- OPTIONAL ----
# Anthropic key is unused by the deterministic pipeline. Leave blank.
# ANTHROPIC_API_KEY=
