# ------------------------------------------------------------
# Stockiya backend environment
#
# setup.bat copies this file to backend/.env on first run.
# Edit backend/.env (NOT this file) if you already have one.
# ------------------------------------------------------------

# ---- DATA SOURCE ----
# Pick exactly one path to real OHLCV. If none of the three below
# is satisfiable on your machine, EVERY ticker will fail at [I] Ingest
# and you will see 0 picks.
#
# (a) DEMO_MODE=1  -->  synthetic in-memory OHLCV. Always works.
#                       UI/dev only. DO NOT trade on these prices.
# (b) DATA_SOURCE=yahoo  -->  live Yahoo Finance. Needs internet.
#                            May be blocked on corporate networks.
# (c) DATA_SOURCE=bhavcopy + STOCKYA_OHLCV_DIR=<abs path>
#                       -->  local per-symbol NSE CSV cache. Populate it
#                            yourself (or via the Stockya-tuner ingestor);
#                            Stockya only reads, never writes to it.
#
# Recommended first run: DEMO_MODE=1 (verifies the wiring), then flip
# to yahoo or bhavcopy once you have a working data path.

DEMO_MODE=1
DATA_SOURCE=yahoo

# Only used when DATA_SOURCE=bhavcopy. Absolute path to a directory
# containing <SYMBOL>.NS.csv files (Date, Open, High, Low, Close, Volume).
# Leave blank to fall back to the sibling Stockya-tuner cache — NOT
# recommended (violates the "no cross-project data" project rule).
# STOCKYA_OHLCV_DIR=

# ---- OPTIONAL ----
# Anthropic key is unused by the deterministic pipeline; kept for parity
# with older docs. Leave blank.
# ANTHROPIC_API_KEY=

# Account size (INR) used by [PS] Position Sizer. Default 100000 = 1 lakh.
# STOCKYA_ACCOUNT_VALUE=100000
