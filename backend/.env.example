# 1 = bundled fixtures (UI dev only — DO NOT TRADE ON THESE PRICES)
# 0 = live Yahoo Finance data (recommended)
DEMO_MODE=0

# yahoo (default) | bhavcopy (TODO)
DATA_SOURCE=yahoo

# Composite score floor for a ticker to be surfaced. 60 = sure-shot only.
# Lower it (e.g. 45) for more picks per day at lower conviction.
MIN_COMPOSITE=60
